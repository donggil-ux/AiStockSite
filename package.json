{
  "name": "stockai-server",
  "version": "1.0.0",
  "description": "StockAI – Yahoo Finance 백엔드 프록시 서버",
  "main": "server.js",
  "scripts": {
    "start": "node --max-http-header-size=65536 server.js",
    "dev": "nodemon --exec 'node --max-http-header-size=65536' server.js",
    "validate": "node -e \"require('./server.js'); console.log('✅ server.js loads OK')\"",
    "smoke": "node scripts/smoke-test.js",
    "test": "npm run validate && npm run smoke",
    "vercel-build": "npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.99.1",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.5.6",
    "multer": "^2.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
