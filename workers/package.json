{
  "name": "stockai-workers",
  "version": "1.0.0",
  "description": "StockAI 백엔드 — Cloudflare Workers (Vercel hybrid)",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create stockai-db",
    "db:migrate": "wrangler d1 execute stockai-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute stockai-db --local --file=./schema.sql",
    "kv:create": "wrangler kv:namespace create CACHE"
  },
  "devDependencies": {
    "wrangler": "^3.114.17"
  }
}
